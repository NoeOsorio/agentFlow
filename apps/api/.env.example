# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentflow

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Security
AGENTFLOW_SECRET_KEY=change-me-in-production
INTERNAL_SECRET=change-me-in-production

# Environment
AGENTFLOW_ENV=development

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional
KNOWLEDGE_BASE_URL=
