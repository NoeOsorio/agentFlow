{
  "name": "agentflow",
  "private": true,
  "scripts": {
    "setup": "pnpm install && pnpm setup:python",
    "setup:python": "cd apps/api && uv sync --group dev && cd ../../services/runtime && uv sync --group dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
